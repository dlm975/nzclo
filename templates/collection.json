{
  "sections": {
    "banner": {
      "type": "main-collection-banner",
      "settings": {
        "show_collection_description": true,
        "show_collection_image": false,
        "color_scheme": "scheme-1"
      }
    },
    "category-nav": {
      "type": "collection-category-nav",
      "blocks": {
        "all": {
          "type": "category",
          "settings": { "label": "All", "link": "/collections/all" }
        },
        "tops": {
          "type": "category",
          "settings": { "label": "Tops", "link": "/collections/tops" }
        },
        "pants": {
          "type": "category",
          "settings": { "label": "Pants", "link": "/collections/pants" }
        },
        "shorts": {
          "type": "category",
          "settings": { "label": "Shorts", "link": "/collections/shorts" }
        }
      },
      "block_order": ["all", "tops", "pants", "shorts"],
      "settings": { "color_scheme": "scheme-1" }
    },
    "product-grid": {
      "type": "main-collection-product-grid",
      "settings": {
        "products_per_page": 16,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "adapt",
        "image_shape": "default",
        "show_secondary_image": false,
        "show_vendor": false,
        "show_rating": false,
        "quick_add": "none",
        "enable_filtering": true,
        "filter_type": "horizontal",
        "enable_sorting": true,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    }
  },
  "order": [
    "banner",
    "category-nav",
    "product-grid"
  ]
}
