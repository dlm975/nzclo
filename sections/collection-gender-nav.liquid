<style>
  .gender-nav {
    padding: 16px 0 2px;
  }
  .gender-nav__inner {
    display: flex;
    justify-content: center;
    gap: 32px;
    padding: 0 20px;
  }
  .gender-nav__item {
    text-decoration: none;
    color: rgba(var(--color-foreground), 0.5);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 4px 2px 7px;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .gender-nav__item:hover {
    color: rgb(var(--color-foreground));
  }
  .gender-nav__item[aria-current="page"] {
    color: rgb(var(--color-foreground));
    font-weight: 700;
    border-bottom-color: rgb(var(--color-foreground));
  }
</style>

{%- liquid
  assign men_tag = section.settings.men_tag | handleize
  assign women_tag = section.settings.women_tag | handleize

  assign base_url = collection.url
  if base_url == blank
    assign base_url = '/collections/all'
  endif

  assign current_gender = ''
  assign path_parts = request.path | split: '/'
  if path_parts.size == 4 and path_parts[1] == 'collections'
    assign last_part = path_parts | last | handleize
    if last_part == men_tag or last_part == women_tag
      assign current_gender = last_part
    endif
  endif
  for tag in collection.current_tags
    assign tag_handle = tag | handleize
    if tag_handle == men_tag or tag_handle == women_tag
      assign current_gender = tag_handle
    endif
  endfor
-%}

<nav class="gender-nav color-{{ section.settings.color_scheme }}" aria-label="{{ section.settings.aria_label | default: 'Shop by' }}">
  <div class="gender-nav__inner">
    <a
      href="{{ base_url }}"
      class="gender-nav__item"
      {% if current_gender == '' %}aria-current="page"{% endif %}
    >{{ section.settings.all_label }}</a>
    <a
      href="{{ base_url }}/{{ men_tag }}"
      class="gender-nav__item"
      {% if current_gender == men_tag %}aria-current="page"{% endif %}
    >{{ section.settings.men_label }}</a>
    <a
      href="{{ base_url }}/{{ women_tag }}"
      class="gender-nav__item"
      {% if current_gender == women_tag %}aria-current="page"{% endif %}
    >{{ section.settings.women_label }}</a>
  </div>
</nav>

{% schema %}
{
  "name": "Gender nav",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Filters the current collection by product tag. Tag your products 'mens' or 'womens' in Shopify admin for this to work."
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "All label",
      "default": "All"
    },
    {
      "type": "text",
      "id": "men_label",
      "label": "Men label",
      "default": "Men"
    },
    {
      "type": "text",
      "id": "women_label",
      "label": "Women label",
      "default": "Women"
    },
    {
      "type": "text",
      "id": "men_tag",
      "label": "Men product tag",
      "default": "mens"
    },
    {
      "type": "text",
      "id": "women_tag",
      "label": "Women product tag",
      "default": "womens"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Gender nav"
    }
  ]
}
{% endschema %}
