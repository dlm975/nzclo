{%- style -%}
  .social-proof {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .social-proof {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .social-proof__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
  }
  .social-proof__header {
    text-align: center;
    margin-bottom: 24px;
  }
  .social-proof__heading {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }
  .social-proof__subheading {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 6px 0 0;
  }
  .social-proof__track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .social-proof__track::-webkit-scrollbar { display: none; }
  @media screen and (min-width: 750px) {
    .social-proof__track {
      overflow-x: visible;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
    }
  }
  .social-proof__card {
    flex: 0 0 185px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  @media screen and (min-width: 750px) {
    .social-proof__card {
      flex: 0 0 210px;
    }
  }
  .social-proof__video-wrap {
    position: relative;
    width: 100%;
    padding-top: 177.78%;
    border-radius: 6px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.05);
  }
  /* Reset TikTok blockquote sizing so it fills our wrapper */
  .social-proof__video-wrap .tiktok-embed {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    min-width: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
  }
  /* After embed.js fires, force the generated iframe to fill the container */
  .social-proof__video-wrap iframe {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    border: none !important;
  }
  .social-proof__caption {
    font-size: 11px;
    font-weight: 500;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
  <div class="social-proof color-{{ section.settings.color_scheme }}">
    <div class="social-proof__inner">
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="social-proof__header">
          {%- if section.settings.heading != blank -%}
            <p class="social-proof__heading">{{ section.settings.heading }}</p>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="social-proof__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="social-proof__track">
        {%- for block in section.blocks -%}
          {%- if block.settings.embed_code != blank -%}
            <div class="social-proof__card" {{ block.shopify_attributes }}>
              <div class="social-proof__video-wrap">
                {{ block.settings.embed_code }}
              </div>
              {%- if block.settings.caption != blank -%}
                <p class="social-proof__caption">{{ block.settings.caption }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {{- 'https://www.tiktok.com/embed.js' | script_tag -}}

  <script>
    (function () {
      function fitEmbeds() {
        document.querySelectorAll('.social-proof__video-wrap iframe').forEach(function (iframe) {
          iframe.style.cssText = 'position:absolute!important;top:0!important;left:0!important;width:100%!important;height:100%!important;border:none!important;';
        });
      }
      // Run immediately in case embed.js already fired, then again after a short delay
      fitEmbeds();
      setTimeout(fitEmbeds, 1500);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Social proof videos",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow label",
      "default": "As seen on"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Heading",
      "default": "Real people, real fits"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "html",
          "id": "embed_code",
          "label": "Embed code",
          "info": "Paste the TikTok embed code (share → embed on TikTok.com)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "e.g. @username"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
