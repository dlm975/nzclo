{%- style -%}
  .social-proof {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .social-proof {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .social-proof__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 20px;
  }
  .social-proof__header {
    text-align: center;
    margin-bottom: 24px;
  }
  .social-proof__heading {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }
  .social-proof__subheading {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 6px 0 0;
  }
  .social-proof__track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .social-proof__track::-webkit-scrollbar { display: none; }
  @media screen and (min-width: 750px) {
    .social-proof__track {
      overflow-x: visible;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
    }
  }
  .social-proof__card {
    flex: 0 0 185px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  @media screen and (min-width: 750px) {
    .social-proof__card {
      flex: 0 0 210px;
    }
  }
  .social-proof__video-wrap {
    position: relative;
    width: 100%;
    padding-top: 177.78%;
    border-radius: 6px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.05);
  }
  .social-proof__video-wrap iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .social-proof__platform {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 22px;
    height: 22px;
    opacity: 0.85;
    z-index: 1;
    pointer-events: none;
  }
  .social-proof__caption {
    font-size: 11px;
    font-weight: 500;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
  <div class="social-proof color-{{ section.settings.color_scheme }}">
    <div class="social-proof__inner">
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="social-proof__header">
          {%- if section.settings.heading != blank -%}
            <p class="social-proof__heading">{{ section.settings.heading }}</p>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="social-proof__subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="social-proof__track">
        {%- for block in section.blocks -%}
          {%- assign raw_url = block.settings.video_url | strip -%}
          {%- assign is_tiktok = false -%}
          {%- assign is_instagram = false -%}

          {%- if raw_url contains 'tiktok.com' -%}
            {%- assign is_tiktok = true -%}
            {%- assign id_parts = raw_url | split: '/video/' -%}
            {%- assign video_id = id_parts[1] | split: '?' | first | split: '/' | first -%}
            {%- assign embed_url = 'https://www.tiktok.com/embed/v2/' | append: video_id -%}
          {%- elsif raw_url contains 'instagram.com' -%}
            {%- assign is_instagram = true -%}
            {%- assign reel_parts = raw_url | split: '/reel/' -%}
            {%- if reel_parts.size > 1 -%}
              {%- assign shortcode = reel_parts[1] | split: '/' | first | split: '?' | first -%}
            {%- else -%}
              {%- assign p_parts = raw_url | split: '/p/' -%}
              {%- assign shortcode = p_parts[1] | split: '/' | first | split: '?' | first -%}
            {%- endif -%}
            {%- assign embed_url = 'https://www.instagram.com/p/' | append: shortcode | append: '/embed/' -%}
          {%- else -%}
            {%- assign embed_url = raw_url -%}
          {%- endif -%}

          {%- if embed_url != blank -%}
            <div class="social-proof__card" {{ block.shopify_attributes }}>
              <div class="social-proof__video-wrap">
                {%- if is_tiktok -%}
                  <svg class="social-proof__platform" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.96a8.19 8.19 0 0 0 4.79 1.53V7.01a4.85 4.85 0 0 1-1.02-.32z"/>
                  </svg>
                {%- elsif is_instagram -%}
                  <svg class="social-proof__platform" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                  </svg>
                {%- endif -%}
                <iframe
                  src="{{ embed_url }}"
                  loading="lazy"
                  allowfullscreen
                  allow="autoplay; encrypted-media"
                  title="{{ block.settings.caption | default: 'Social video' | escape }}"
                ></iframe>
              </div>
              {%- if block.settings.caption != blank -%}
                <p class="social-proof__caption">{{ block.settings.caption }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Social proof videos",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow label",
      "default": "As seen on"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Heading",
      "default": "Real people, real fits"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL",
          "info": "Paste the full TikTok or Instagram Reel URL"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "info": "e.g. @username"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
