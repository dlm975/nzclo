<style>
  .mission {
    padding: 80px 0;
    background-color: #1b1c17;
    color: #fbfaf0;
  }

  .mission__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 64px;
  }

  @media screen and (max-width: 749px) {
    .mission {
      padding: 56px 0;
    }
    .mission__inner {
      grid-template-columns: 1fr;
      gap: 48px;
      padding: 0 20px;
    }
    .mission__visual {
      order: -1;
    }
  }

  .mission__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #747878;
    margin: 0 0 20px;
  }

  .mission__heading {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fbfaf0;
    margin: 0 0 28px;
  }

  .mission__body {
    font-size: 16px;
    line-height: 1.7;
    color: #c4c7c7;
    margin: 0 0 36px;
    max-width: 480px;
  }

  .mission__body p + p {
    margin-top: 16px;
  }

  .mission__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #fbfaf0;
    text-decoration: none;
    border-bottom: 1px solid rgba(251,250,240,0.3);
    padding-bottom: 2px;
    transition: border-color 0.15s ease;
  }
  .mission__link:hover {
    border-color: #fbfaf0;
  }

  /* Visual side */
  .mission__visual {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  @media screen and (max-width: 749px) {
    .mission__visual {
      align-items: flex-start;
    }
  }

  .mission__geo {
    width: 100%;
    max-width: 440px;
  }

  .mission__geo-label {
    font-family: var(--font-body-family);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: #747878;
  }

  .mission__geo-place {
    font-family: var(--font-body-family);
    font-size: 28px;
    font-weight: 600;
    letter-spacing: -0.01em;
    fill: #fbfaf0;
  }

  .mission__geo-kanji {
    font-size: 52px;
    font-weight: 700;
    letter-spacing: -0.02em;
    fill: rgba(251,250,240,0.08);
  }

  .mission__geo-stat {
    font-family: var(--font-body-family);
    font-size: 11px;
    letter-spacing: 0.04em;
    fill: #747878;
  }
</style>

<section class="mission">
  <div class="mission__inner">
    <div class="mission__text">
      <p class="mission__eyebrow">Our Mission</p>
      <h2 class="mission__heading">Japan's finest.<br>Now in New Zealand.</h2>
      <div class="mission__body">
        <p>Uniqlo has quietly redefined what everyday clothing can be — precise construction, materials engineered to last, and a design language stripped of everything unnecessary.</p>
        <p>New Zealand has never had direct access to it. nzclo changes that. We source genuine pieces and deliver them to your door with honest pricing and no compromise. The real thing, closer to home.</p>
      </div>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="mission__link">
        Shop the collection
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="mission__visual">
      <svg class="mission__geo" viewBox="0 0 440 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

        <!-- Grid lines -->
        <line x1="0" y1="80" x2="440" y2="80" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>
        <line x1="0" y1="160" x2="440" y2="160" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>
        <line x1="0" y1="240" x2="440" y2="240" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>
        <line x1="110" y1="0" x2="110" y2="320" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>
        <line x1="220" y1="0" x2="220" y2="320" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>
        <line x1="330" y1="0" x2="330" y2="320" stroke="rgba(251,250,240,0.05)" stroke-width="1"/>

        <!-- Background kanji: 日本 (Japan) -->
        <text x="30" y="210" class="mission__geo-kanji">日本</text>

        <!-- Japan node -->
        <circle cx="120" cy="140" r="4" fill="#fbfaf0"/>
        <text x="120" y="126" class="mission__geo-label" text-anchor="middle">ORIGIN</text>
        <text x="120" y="168" class="mission__geo-place" text-anchor="middle">Japan</text>

        <!-- Arc / flight path (dashed curve) -->
        <path
          d="M 148 140 Q 280 60 312 155"
          stroke="rgba(251,250,240,0.3)"
          stroke-width="1"
          stroke-dasharray="4 4"
          fill="none"
        />

        <!-- Arrowhead at NZ end -->
        <path d="M308 148 L316 156 L306 162" stroke="rgba(251,250,240,0.3)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" fill="none"/>

        <!-- Distance label on arc -->
        <text x="230" y="88" class="mission__geo-stat" text-anchor="middle">9,417 km</text>

        <!-- NZ node -->
        <circle cx="320" cy="160" r="4" fill="#fbfaf0"/>
        <text x="320" y="146" class="mission__geo-label" text-anchor="middle">DESTINATION</text>
        <text x="320" y="188" class="mission__geo-place" text-anchor="middle">New Zealand</text>

        <!-- Bottom stat line -->
        <line x1="40" y1="280" x2="400" y2="280" stroke="rgba(251,250,240,0.1)" stroke-width="1"/>
        <text x="40" y="300" class="mission__geo-stat">AUTHENTIC GOODS</text>
        <text x="220" y="300" class="mission__geo-stat" text-anchor="middle">DIRECT SHIPPING</text>
        <text x="400" y="300" class="mission__geo-stat" text-anchor="end">SINCE 2025</text>

      </svg>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mission statement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Mission statement"
    }
  ]
}
{% endschema %}
