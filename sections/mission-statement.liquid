<style>
  .mission {
    padding: 80px 0 64px;
    background-color: #1b1c17;
    color: #fbfaf0;
  }

  .mission__inner {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 64px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 64px;
  }

  @media screen and (max-width: 749px) {
    .mission {
      padding: 48px 0 40px;
    }
    .mission__inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 0 20px;
    }
  }

  .mission__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #747878;
    margin: 0 0 20px;
  }

  .mission__heading {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fbfaf0;
    margin: 0 0 24px;
  }

  .mission__body {
    font-size: 15px;
    line-height: 1.75;
    color: #c4c7c7;
    margin: 0 0 32px;
  }

  .mission__body p + p {
    margin-top: 14px;
  }

  .mission__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fbfaf0;
    text-decoration: none;
    border-bottom: 1px solid rgba(251,250,240,0.3);
    padding-bottom: 2px;
    transition: border-color 0.15s ease;
  }
  .mission__link:hover { border-color: #fbfaf0; }

  .mission__map {
    width: 100%;
    overflow: hidden;
  }

  .mission__map svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .map-label {
    font-family: var(--font-body-family);
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: #747878;
  }

  .map-nz-label {
    font-family: var(--font-body-family);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: #fbfaf0;
  }

  .map-stat {
    font-family: var(--font-body-family);
    font-size: 8px;
    letter-spacing: 0.05em;
    fill: rgba(251,250,240,0.3);
  }
</style>

<section class="mission">
  <div class="mission__inner">

    <div class="mission__text">
      <p class="mission__eyebrow">Our Mission</p>
      <h2 class="mission__heading">Worn worldwide.<br>Finally in&nbsp;New&nbsp;Zealand.</h2>
      <div class="mission__body">
        <p>Uniqlo operates in over 25 countries across Asia, Europe, the Middle East, and North America. Recognised globally for precise construction, functional materials, and a design philosophy defined by restraint.</p>
        <p>New Zealand has never had direct access. nzclo changes that — sourcing genuine pieces and delivering them to your door. Authentic product, no compromise.</p>
      </div>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="mission__link">
        Shop the collection
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="mission__map">
      <!--
        Equirectangular projection, viewBox 0 0 900 420
        x = (lon + 180) / 360 * 900
        y = (90 - lat) / 180 * 420
        NZ hub approx: cx=882 cy=300
      -->
      <svg viewBox="0 0 900 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="World map showing countries where Uniqlo operates, all connected to New Zealand">

        <!-- Subtle lat/lon grid -->
        <line x1="0" y1="105" x2="900" y2="105" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>
        <line x1="0" y1="210" x2="900" y2="210" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>
        <line x1="0" y1="315" x2="900" y2="315" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>
        <line x1="225" y1="0" x2="225" y2="420" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>
        <line x1="450" y1="0" x2="450" y2="420" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>
        <line x1="675" y1="0" x2="675" y2="420" stroke="rgba(251,250,240,0.04)" stroke-width="0.5"/>

        <!-- ── Continent fills ── -->
        <g fill="rgba(251,250,240,0.09)" stroke="rgba(251,250,240,0.12)" stroke-width="0.4" stroke-linejoin="round">

          <!-- North America -->
          <path d="M38,68 L213,16 L300,16 L325,100 L288,168 L243,190 L225,168 L175,157 L158,135 L140,98 L125,84 Z"/>

          <!-- Greenland -->
          <path d="M313,16 L405,19 L405,35 L350,58 L318,40 Z"/>

          <!-- South America -->
          <path d="M253,190 L363,222 L363,245 L330,275 L288,338 L268,327 L268,292 L250,222 L250,210 Z"/>

          <!-- Europe (including Scandinavia) -->
          <path d="M428,126 L428,107 L438,93 L443,75 L470,63 L520,44 L530,58 L520,84 L540,112 L515,124 L488,124 L438,126 Z"/>

          <!-- Africa -->
          <path d="M438,128 L408,177 L413,215 L473,222 L490,292 L515,289 L538,280 L550,233 L578,184 L560,158 L543,158 L530,140 L513,135 L480,133 Z"/>

          <!-- Asia (main body incl. Middle East & Indian subcontinent) -->
          <path d="M523,114 L575,47 L800,40 L858,77 L770,124 L750,175 L730,205 L708,212 L650,191 L620,158 L560,170 L543,158 L523,158 Z"/>

          <!-- SE Asia peninsula (Indochina/Malay) -->
          <path d="M700,175 L730,168 L742,192 L728,210 L710,210 L698,196 Z"/>

          <!-- Australia -->
          <path d="M713,262 L785,244 L820,248 L830,274 L815,300 L770,308 L732,295 Z"/>

          <!-- New Zealand (rough north+south islands) -->
          <path d="M876,293 L886,298 L884,314 L876,310 Z"/>
          <path d="M874,316 L881,319 L877,333 L869,328 Z"/>

        </g>

        <!-- ── Lines from every Uniqlo country pin → NZ hub (882, 300) ── -->
        <g stroke="rgba(251,250,240,0.14)" stroke-width="0.7" fill="none">
          <!-- North America -->
          <line x1="265" y1="114" x2="882" y2="300"/>
          <line x1="155" y1="130" x2="882" y2="300"/>
          <line x1="253" y1="109" x2="882" y2="300"/>
          <!-- Europe -->
          <line x1="450" y1="89"  x2="882" y2="300"/>
          <line x1="458" y1="100" x2="882" y2="300"/>
          <line x1="475" y1="91"  x2="882" y2="300"/>
          <line x1="460" y1="91"  x2="882" y2="300"/>
          <line x1="463" y1="89"  x2="882" y2="300"/>
          <line x1="475" y1="79"  x2="882" y2="300"/>
          <line x1="495" y1="70"  x2="882" y2="300"/>
          <line x1="513" y1="65"  x2="882" y2="300"/>
          <line x1="480" y1="109" x2="882" y2="300"/>
          <line x1="440" y1="117" x2="882" y2="300"/>
          <line x1="488" y1="93"  x2="882" y2="300"/>
          <line x1="500" y1="89"  x2="882" y2="300"/>
          <line x1="530" y1="119" x2="882" y2="300"/>
          <!-- Middle East -->
          <line x1="588" y1="152" x2="882" y2="300"/>
          <line x1="563" y1="154" x2="882" y2="300"/>
          <line x1="570" y1="142" x2="882" y2="300"/>
          <line x1="578" y1="152" x2="882" y2="300"/>
          <line x1="575" y1="149" x2="882" y2="300"/>
          <line x1="593" y1="158" x2="882" y2="300"/>
          <!-- South Asia -->
          <line x1="650" y1="158" x2="882" y2="300"/>
          <line x1="675" y1="154" x2="882" y2="300"/>
          <!-- SE Asia -->
          <line x1="710" y1="207" x2="882" y2="300"/>
          <line x1="725" y1="200" x2="882" y2="300"/>
          <line x1="703" y1="175" x2="882" y2="300"/>
          <line x1="755" y1="179" x2="882" y2="300"/>
          <line x1="738" y1="221" x2="882" y2="300"/>
          <line x1="720" y1="177" x2="882" y2="300"/>
          <line x1="713" y1="182" x2="882" y2="300"/>
          <!-- East Asia -->
          <line x1="790" y1="126" x2="882" y2="300"/>
          <line x1="713" y1="128" x2="882" y2="300"/>
          <line x1="770" y1="124" x2="882" y2="300"/>
          <line x1="753" y1="154" x2="882" y2="300"/>
          <line x1="735" y1="158" x2="882" y2="300"/>
          <!-- Australia -->
          <line x1="770" y1="270" x2="882" y2="300"/>
        </g>

        <!-- ── Country pins ── -->
        <g fill="rgba(251,250,240,0.55)">
          <!-- North America -->
          <circle cx="265" cy="114" r="2.5"/>
          <circle cx="155" cy="130" r="2.5"/>
          <circle cx="253" cy="109" r="2.5"/>
          <!-- Europe -->
          <circle cx="450" cy="89"  r="2"/>
          <circle cx="458" cy="100" r="2"/>
          <circle cx="475" cy="91"  r="2"/>
          <circle cx="460" cy="91"  r="2"/>
          <circle cx="463" cy="89"  r="2"/>
          <circle cx="475" cy="79"  r="2"/>
          <circle cx="495" cy="70"  r="2"/>
          <circle cx="513" cy="65"  r="2"/>
          <circle cx="480" cy="109" r="2"/>
          <circle cx="440" cy="117" r="2"/>
          <circle cx="488" cy="93"  r="2"/>
          <circle cx="500" cy="89"  r="2"/>
          <circle cx="530" cy="119" r="2"/>
          <!-- Middle East -->
          <circle cx="588" cy="152" r="2"/>
          <circle cx="563" cy="154" r="2"/>
          <circle cx="570" cy="142" r="2"/>
          <circle cx="578" cy="152" r="2"/>
          <circle cx="575" cy="149" r="2"/>
          <circle cx="593" cy="158" r="2"/>
          <!-- South Asia -->
          <circle cx="650" cy="158" r="2.5"/>
          <circle cx="675" cy="154" r="2"/>
          <!-- SE Asia -->
          <circle cx="710" cy="207" r="2"/>
          <circle cx="725" cy="200" r="2"/>
          <circle cx="703" cy="175" r="2"/>
          <circle cx="755" cy="179" r="2"/>
          <circle cx="738" cy="221" r="2"/>
          <circle cx="720" cy="177" r="2"/>
          <circle cx="713" cy="182" r="2"/>
          <!-- East Asia -->
          <circle cx="790" cy="126" r="2.5"/>
          <circle cx="713" cy="128" r="2.5"/>
          <circle cx="770" cy="124" r="2"/>
          <circle cx="753" cy="154" r="2"/>
          <circle cx="735" cy="158" r="2"/>
          <!-- Australia -->
          <circle cx="770" cy="270" r="2.5"/>
        </g>

        <!-- ── New Zealand hub ── -->
        <circle cx="882" cy="300" r="16" fill="rgba(251,250,240,0.06)"/>
        <circle cx="882" cy="300" r="10" fill="rgba(251,250,240,0.12)"/>
        <circle cx="882" cy="300" r="5"  fill="#fbfaf0"/>

        <!-- NZ label -->
        <text x="872" y="282" text-anchor="end" class="map-nz-label">NEW ZEALAND</text>
        <text x="872" y="293" text-anchor="end" class="map-label">DESTINATION</text>

        <!-- Bottom caption -->
        <text x="10" y="415" class="map-stat">25+ COUNTRIES. ONE MISSING — UNTIL NOW.</text>

      </svg>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Mission statement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Mission statement"
    }
  ]
}
{% endschema %}
