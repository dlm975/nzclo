<style>
  .cat-nav {
    padding: 20px 0 4px;
  }
  .cat-nav__inner {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 20px;
  }
  .cat-nav__inner::-webkit-scrollbar { display: none; }

  @media screen and (min-width: 750px) {
    .cat-nav__inner {
      padding: 0 40px;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }

  .cat-nav__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    width: 72px;
  }

  .cat-nav__img-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid transparent;
    background: #efeee5;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease;
  }

  .cat-nav__item:hover .cat-nav__img-wrap,
  .cat-nav__item[aria-current="page"] .cat-nav__img-wrap {
    border-color: #1b1c17;
  }

  .cat-nav__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cat-nav__label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
  }
</style>

{%- if section.blocks.size > 0 -%}
  <nav class="cat-nav color-{{ section.settings.color_scheme }}">
    <div class="cat-nav__inner">
      {%- for block in section.blocks -%}
        {%- assign is_current = false -%}
        {%- if block.settings.link == request.path -%}
          {%- assign is_current = true -%}
        {%- endif -%}
        <a
          href="{{ block.settings.link }}"
          class="cat-nav__item"
          {% if is_current %}aria-current="page"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="cat-nav__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 128 }}"
                alt="{{ block.settings.label | escape }}"
                width="64"
                height="64"
                loading="lazy"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <span class="cat-nav__label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "Category nav",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category nav",
      "blocks": [
        { "type": "category", "settings": { "label": "All" } },
        { "type": "category", "settings": { "label": "Tops" } },
        { "type": "category", "settings": { "label": "Pants" } },
        { "type": "category", "settings": { "label": "Shorts" } }
      ]
    }
  ]
}
{% endschema %}
