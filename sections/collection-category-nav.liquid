<style>
  .cat-nav {
    padding: 8px 0 4px;
  }
  .cat-nav__inner {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 20px;
    justify-content: center;
  }
  .cat-nav__inner::-webkit-scrollbar { display: none; }

  @media screen and (min-width: 750px) {
    .cat-nav__inner {
      padding: 0 40px;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      overflow-x: visible;
    }
  }

  .cat-nav__item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    width: 72px;
  }

  .cat-nav__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease;
  }

  .cat-nav__item:hover .cat-nav__icon-wrap,
  .cat-nav__item[aria-current="page"] .cat-nav__icon-wrap {
    border-color: #1b1c17;
  }

  .cat-nav__icon-wrap svg {
    width: 30px;
    height: 30px;
    display: block;
  }

  .cat-nav__label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-align: center;
    line-height: 1.2;
    white-space: nowrap;
  }
</style>

{%- if section.blocks.size > 0 -%}
  <nav class="cat-nav color-{{ section.settings.color_scheme }}">
    <div class="cat-nav__inner">
      {%- for block in section.blocks -%}
        {%- assign is_current = false -%}
        {%- if block.settings.link == request.path -%}
          {%- assign is_current = true -%}
        {%- endif -%}

        {%- capture cat_icon -%}
          {%- case block.settings.icon -%}

            {%- when 'all' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="8" height="8"/>
                <rect x="13" y="3" width="8" height="8"/>
                <rect x="3" y="13" width="8" height="8"/>
                <rect x="13" y="13" width="8" height="8"/>
              </svg>

            {%- when 'tops' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 3L2 7L5 12L8 11V22H16V11L19 12L22 7L15 3Q12 5 9 3Z"/>
              </svg>

            {%- when 'pants' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 3H19V22H14L12 13L10 22H5V3Z"/>
              </svg>

            {%- when 'shorts' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 3H19V14H14L12 10L10 14H5V3Z"/>
              </svg>

            {%- when 'hoodies' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 3L2 7L5 12L8 11V22H16V11L19 12L22 7L15 3L12 6L9 3Z"/>
                <rect x="9" y="16" width="6" height="5"/>
              </svg>

            {%- when 'outerwear' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M8 2L2 7L5 12L8 11V22H16V11L19 12L22 7L16 2L12 6L8 2Z"/>
                <path d="M8 2L10 8L12 6"/>
                <path d="M16 2L14 8L12 6"/>
              </svg>

            {%- when 'accessories' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3C13.1 3 14 3.9 14 5C14 5.8 13.5 6.4 12.8 6.8L21 14H3L11.2 6.8C10.5 6.4 10 5.8 10 5C10 3.9 10.9 3 12 3Z"/>
                <line x1="3" y1="14" x2="21" y2="14"/>
              </svg>

            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="8" height="8"/>
                <rect x="13" y="3" width="8" height="8"/>
                <rect x="3" y="13" width="8" height="8"/>
                <rect x="13" y="13" width="8" height="8"/>
              </svg>

          {%- endcase -%}
        {%- endcapture -%}

        <a
          href="{{ block.settings.link }}"
          class="cat-nav__item"
          {% if is_current %}aria-current="page"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="cat-nav__icon-wrap">
            {{ cat_icon }}
          </div>
          {%- if block.settings.label != blank -%}
            <span class="cat-nav__label">{{ block.settings.label }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </nav>
{%- endif -%}

{% schema %}
{
  "name": "Category nav",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "all",
          "options": [
            { "value": "all",         "label": "All (grid)" },
            { "value": "tops",        "label": "Tops (t-shirt)" },
            { "value": "pants",       "label": "Pants" },
            { "value": "shorts",      "label": "Shorts" },
            { "value": "hoodies",     "label": "Hoodies" },
            { "value": "outerwear",   "label": "Outerwear (jacket)" },
            { "value": "accessories", "label": "Accessories (hanger)" }
          ]
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category nav",
      "blocks": [
        { "type": "category", "settings": { "icon": "all",    "label": "All" } },
        { "type": "category", "settings": { "icon": "tops",   "label": "Tops" } },
        { "type": "category", "settings": { "icon": "pants",  "label": "Pants" } },
        { "type": "category", "settings": { "icon": "shorts", "label": "Shorts" } }
      ]
    }
  ]
}
{% endschema %}
